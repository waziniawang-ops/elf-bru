# Django core
SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-app.onrender.com,www.yourdomain.com

# Database (Render PostgreSQL, Supabase, ElephantSQL, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# CORS — set to your Flutter web frontend URL
CORS_ALLOWED_ORIGINS=https://your-frontend.netlify.app,https://yourusername.github.io

# Cloudinary — for persistent product images & payment screenshots
# Sign up free at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Bank account details shown to customers on checkout
BANK_NAME=Your Bank Name
BANK_ACCOUNT_NAME=Your Business Name
BANK_ACCOUNT_NUMBER=1234567890
BANK_INSTRUCTIONS=Transfer the exact amount and upload a screenshot of your transfer.

# Display currency symbol (default: $)
CURRENCY_SYMBOL=$
